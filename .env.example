# ============================================================
# Qonnect Backend — Environment Variables
# Copy this file to .env and fill in your real values
# NEVER commit .env to GitHub
# ============================================================

# ── Google Gemini AI ──────────────────────────────────────
API_KEY=your_google_gemini_api_key_here

# ── Authentication ────────────────────────────────────────
# Generate a long random string — used to sign JWT login tokens
# Example: openssl rand -base64 32
JWT_SECRET=change_this_to_a_long_random_secret_string

# ── Server ────────────────────────────────────────────────
PORT=8080
CORS_ORIGIN=https://ops.yourdomain.com

# ── WhatsApp (Meta Business API) ─────────────────────────
WA_VERIFY_TOKEN=your_webhook_verify_token
WA_PHONE_NUMBER_ID=your_meta_phone_number_id
WA_ACCESS_TOKEN=your_meta_permanent_access_token

# ── n8n Automation (optional — leave blank to disable) ───
# Set this when you connect n8n for notifications and reports
N8N_WEBHOOK_URL=

# ── Frontend (handled by Nginx proxy in production) ───────
VITE_API_BASE_URL=/api
